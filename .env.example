# Copy into `.env` for local development or set in Vercel.

VITE_APP_NAME=GigRadar
# Local dev: leave empty to use Vite proxy → gr-backend on 127.0.0.1:8787 (see vite.config.ts).
# Hosted: full Worker URL, e.g. https://gr-backend-dev.gigradar.workers.dev
# (Do not use the frontend Vercel hostname here; bare hosts must be host-only — gr-ui.example.com
# is normalized to https://gr-ui.example.com, never a path under localhost.)
VITE_API_BASE_URL=
VITE_ENABLE_DEMO_MODE=true

# Auth runs through gr-backend (`/api/auth/*`); Supabase keys stay on the server only.
# Configure Supabase (providers, Site URL, Redirect URLs) in the dashboard — see gr-backend README.

# OpenAI (server-side only; do not expose in frontend code)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: Vercel serverless proxies. Local dev: Mapbox goes through gr-backend — use /api/geocode (Vite proxy).
VITE_OPENAI_PROXY_URL=/api/openai-recommend
VITE_MAPBOX_PROXY_URL=/api/geocode

# Mapbox (server-side preferred)
MAPBOX_ACCESS_TOKEN=
